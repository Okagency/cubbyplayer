<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_settings_sheet">

    <!-- 드래그 핸들 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_settings_drag_handle" />

    <!-- 헤더 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvSegmentListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="구간 리스트"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface" />

        <ImageButton
            android:id="@+id/btnCloseSegmentDialog"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="@color/on_surface_secondary"
            android:contentDescription="닫기" />

        <android.widget.Button
            android:id="@+id/btnDeleteAllSegments"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_toStartOf="@id/btnCloseSegmentDialog"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:text="전체 삭제"
            android:textSize="12sp"
            android:textColor="#FF6B6B"
            android:background="@drawable/bg_settings_btn_outline"
            android:paddingHorizontal="12dp"
            android:minWidth="0dp"
            android:minHeight="0dp" />
    </RelativeLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSegmentList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false" />

</LinearLayout>
