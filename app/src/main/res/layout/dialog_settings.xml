<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_settings_sheet">

    <!-- 드래그 핸들 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_settings_drag_handle" />

    <!-- 헤더: 타이틀 + 닫기 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="설정"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface" />

        <ImageButton
            android:id="@+id/btnCloseSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:tint="@color/on_surface_secondary"
            android:contentDescription="닫기" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ==================== 섹션 1: 플레이어 ==================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="플레이어"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_light"
                android:paddingStart="4dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_card"
                android:padding="16dp">

                <!-- 플레이어 엔진 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_movie"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="플레이어 엔진"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <Spinner
                        android:id="@+id/spinnerPlayerEngine"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="110dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 소리 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_volume_on"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="소리"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchSound"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 시작시 무음 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_volume_off"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="시작시 무음"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchStartMute"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 시작시 최대밝기 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_brightness"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="시작시 최대밝기"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchStartMaxBrightness"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- ==================== 섹션 2: 제스처 ==================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="제스처"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_light"
                android:paddingStart="4dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_card"
                android:padding="16dp">

                <!-- 스킵 시간 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_fast_forward"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="스킵 시간"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <Spinner
                        android:id="@+id/spinnerSkipTime"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="90dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 스킵 방향 반전 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_swap"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="스킵 방향 반전"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchSkipDirectionReversed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 스와이프 민감도 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_swipe"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="스와이프 민감도"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <Spinner
                        android:id="@+id/spinnerSensitivity"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="80dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 밝기 스와이프 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_brightness"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="밝기 스와이프"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchBrightnessSwipe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 볼륨 스와이프 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_volume_on"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="볼륨 스와이프"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchVolumeSwipe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- ==================== 섹션 3: 재생 ==================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="재생"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_light"
                android:paddingStart="4dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_card"
                android:padding="16dp">

                <!-- 버퍼링 모드 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_schedule"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="버퍼링 모드"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <Spinner
                        android:id="@+id/spinnerBufferMode"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="100dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 시크 모드 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_fast_forward"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="시크 모드"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <Spinner
                        android:id="@+id/spinnerSeekMode"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="100dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 폴더 내 연속 재생 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_folder"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="폴더 내 연속 재생"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchContinuousPlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- 내장 자막 (visibility gone by default) -->
                <View
                    android:id="@+id/dividerEmbeddedSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layoutEmbeddedSubtitles"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_subtitles"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="내장 자막"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <Spinner
                        android:id="@+id/spinnerEmbeddedSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="110dp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 캐스팅 방식 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_cast"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="캐스팅 방식"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <Spinner
                        android:id="@+id/spinnerCastMode"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:minWidth="120dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ==================== 섹션 4: 구간 재생 관리 ==================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="구간 재생 관리"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_light"
                android:paddingStart="4dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_card"
                android:padding="16dp">

                <!-- 추출 경로 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_save"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="추출 경로"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <EditText
                        android:id="@+id/editSegmentSavePath"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:text="/storage/emulated/0/Movies"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_secondary"
                        android:singleLine="true"
                        android:inputType="text"
                        android:background="@drawable/bg_settings_input" />

                    <ImageButton
                        android:id="@+id/btnSelectFolder"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_folder"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:tint="@color/primary_light"
                        android:contentDescription="폴더 선택" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/thumbnail_background" />

                <!-- 구간 파일 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="10dp"
                    android:paddingBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_file"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="구간 파일"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />
                </LinearLayout>

                <EditText
                    android:id="@+id/editSegmentFilePath"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_secondary"
                    android:singleLine="true"
                    android:inputType="text"
                    android:enabled="false"
                    android:background="@drawable/bg_settings_input" />

                <!-- 백업/복원 버튼 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="12dp">

                    <Button
                        android:id="@+id/btnBackupSegmentFile"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="내려받기"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface"
                        android:background="@drawable/bg_settings_btn_outline"
                        android:layout_marginEnd="6dp"
                        android:drawableStart="@drawable/ic_download"
                        android:drawablePadding="6dp"
                        android:drawableTint="@color/primary_light" />

                    <Button
                        android:id="@+id/btnRestoreSegmentFile"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="올리기"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface"
                        android:background="@drawable/bg_settings_btn_outline"
                        android:layout_marginStart="6dp"
                        android:drawableStart="@drawable/ic_upload"
                        android:drawablePadding="6dp"
                        android:drawableTint="@color/primary_light" />
                </LinearLayout>
            </LinearLayout>

            <!-- ==================== 섹션 5: 자막 캐시 ==================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="자막 캐시"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_light"
                android:paddingStart="4dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_card"
                android:padding="16dp">

                <!-- 자막 캐시 사용 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_cache"
                        android:tint="@color/primary_light" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="자막 캐시 사용"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:layout_marginStart="12dp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchSubtitleCache"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 캐시 경로 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="캐시 경로"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_secondary" />

                    <TextView
                        android:id="@+id/cachePathText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="/data/data/com.splayer.video/cache/converted_subtitles/"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"
                        android:paddingTop="2dp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="32dp"
                    android:background="@color/thumbnail_background" />

                <!-- 캐시 파일 수 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="캐시 파일 수"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/cacheFileCountText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0개 파일"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_light" />
                </LinearLayout>

                <!-- 캐시 삭제 버튼 -->
                <Button
                    android:id="@+id/btnClearCache"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="4dp"
                    android:text="캐시 삭제"
                    android:textSize="13sp"
                    android:textColor="#FF6B6B"
                    android:background="@drawable/bg_settings_btn_danger"
                    android:drawableStart="@drawable/ic_delete"
                    android:drawablePadding="6dp"
                    android:drawableTint="#FF6B6B" />
            </LinearLayout>

            <!-- ==================== 섹션 6: 플러그인 (플러그인 설치 시에만 표시) ==================== -->
            <LinearLayout
                android:id="@+id/layoutPluginSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="플러그인"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_light"
                    android:paddingStart="4dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_settings_card"
                    android:padding="16dp">

                    <!-- 포맷 변환 -->
                    <LinearLayout
                        android:id="@+id/btnConvertVideo"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_swap"
                            android:tint="@color/primary_light" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="포맷 변환"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface"
                            android:layout_marginStart="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="▶"
                            android:textSize="12sp"
                            android:textColor="@color/on_surface_secondary" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
